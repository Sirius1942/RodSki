<?xml version="1.0" encoding="UTF-8"?>
<cases step_wait="500">
    <!-- TC001: Web登录测试 -->
    <case execute="是" id="TC001" title="Web登录测试" component_type="界面">
        <test_case>
            <test_step action="navigate" model="" data="http://localhost:8000"/>
            <test_step action="type" model="LoginForm" data="L001"/>
        </test_case>
        <post_process>
            <test_step action="close" model="" data=""/>
        </post_process>
    </case>

    <!-- TC002: Web看板验证 -->
    <case execute="是" id="TC002" title="看板数据验证" component_type="界面">
