<?xml version="1.0" encoding="UTF-8"?>
<models>
<model name="LoginForm" type="ui" servicename="">
    <element name="username" type="input">
        <location type="id">loginUsername</location>
    </element>
    <element name="password" type="input">
        <location type="id">loginPassword</location>
    </element>
    <element name="loginBtn" type="button">
        <location type="id">loginBtn</location>
    </element>
</model>

<model name="Dashboard" type="ui" servicename="">
    <element name="totalOrders" type="text">
        <location type="id">totalOrders</location>
    </element>
    <element name="completedOrders" type="text">
        <location type="id">completedOrders</location>
    </element>
</model>

<model name="NavMenu" type="ui" servicename="">
    <element name="testLink" type="link">
        <location type="id">navTest</location>
    </element>
</model>

<model name="TestForm" type="ui" servicename="">
    <element name="username" type="input">
        <location type="id">username</location>
    </element>
    <element name="role" type="select">
        <location type="id">role</location>
    </element>
    <element name="submitBtn" type="button">
        <location type="id">submitBtn</location>
    </element>
    <element name="formResult" type="text">
        <location type="id">formResult</location>
    </element>
</model>

<model name="LoginAPI" type="interface" servicename="">
    <element name="_method" type="http_method">
        <location type="static">POST</location>
    </element>
    <element name="_url" type="http_url">
        <location type="static">http://localhost:8000/api/login</location>
    </element>
    <element name="username" type="field">
        <location type="field">username</location>
    </element>
    <element name="password" type="field">
        <location type="field">password</location>
    </element>
</model>

<model name="OrderAPI" type="interface" servicename="">
    <element name="_method" type="http_method">
        <location type="static">GET</location>
    </element>
    <element name="_url" type="http_url">
        <location type="static">http://localhost:8000/api/orders</location>
    </element>
</model>

<model name="QuerySQL" type="interface" servicename="">
    <element name="sql" type="field">
        <location type="field">sql</location>
    </element>
</model>

<model name="UIActions" type="ui" servicename="">
    <element name="hoverBtn" type="button">
        <location type="id">hoverBtn</location>
    </element>
    <element name="doubleClickBtn" type="button">
        <location type="id">doubleClickBtn</location>
    </element>
    <element name="rightClickBtn" type="button">
        <location type="id">rightClickBtn</location>
    </element>
    <element name="actionResult" type="text">
        <location type="id">actionResult</location>
    </element>
    <element name="scrollArea" type="div">
        <location type="id">scrollArea</location>
    </element>
    <element name="dragSource" type="div">
        <location type="id">dragSource</location>
    </element>
</model>

<model name="ReturnTest" type="ui" servicename="">
    <element name="username" type="input">
        <location type="id">username</location>
    </element>
    <element name="formResult" type="text">
        <location type="id">formResult</location>
    </element>
</model>

<model name="SetGetVerify" type="ui" servicename="">
    <element name="value" type="text">
        <location type="id">formResult</location>
    </element>
</model>

<model name="GetVerify" type="ui" servicename="">
    <element name="result" type="text">
        <location type="id">formResult</location>
    </element>
</model>

<model name="EvaluateResult" type="ui" servicename="">
    <element name="title" type="text">
        <location type="id">pageTitle</location>
    </element>
</model>

<model name="DemoForm" type="ui" servicename="">
    <element name="username" type="input">
        <location type="id">username</location>
    </element>
    <element name="submitBtn" type="button">
        <location type="id">submitBtn</location>
    </element>
    <auto_capture trigger="type">
        <field name="resultId">
            <location type="id">resultId</location>
        </field>
    </auto_capture>
</model>

<model name="DemoFormVerify" type="ui" servicename="">
    <element name="resultId" type="text">
        <location type="id">resultId</location>
    </element>
</model>

<model name="DemoFormBadCapture" type="ui" servicename="">
    <element name="username" type="input">
        <location type="id">username</location>
    </element>
    <element name="submitBtn" type="button">
        <location type="id">submitBtn</location>
    </element>
    <auto_capture trigger="type">
        <field name="nonExistentField">
            <location type="id">nonExistentField</location>
        </field>
    </auto_capture>
</model>

<model name="LoginAPICapture" type="interface" servicename="">
    <element name="_method" type="http_method">
        <location type="static">POST</location>
    </element>
    <element name="_url" type="http_url">
        <location type="static">http://localhost:8000/api/login</location>
    </element>
    <element name="username" type="field">
        <location type="field">username</location>
    </element>
    <element name="password" type="field">
        <location type="field">password</location>
    </element>
    <auto_capture trigger="send">
        <field name="token" path="data.token"/>
    </auto_capture>
</model>

<model name="GetModel" type="ui" servicename="">
    <element name="formResult" type="text">
        <location type="id">formResult</location>
    </element>
</model>

<model name="GetModelVerify" type="ui" servicename="">
    <element name="formResult" type="text">
        <location type="id">formResult</location>
    </element>
</model>

<model name="ErrorMessage" type="ui" servicename="">
    <element name="errorMsg" type="text">
        <location type="id">loginError</location>
    </element>
</model>

<model name="LocatorTest_ID" type="ui" servicename="">
    <element name="input" type="input">
        <location type="id">input_by_id</location>
    </element>
    <element name="button" type="button">
        <location type="id">btn_by_id</location>
    </element>
    <element name="result" type="text">
