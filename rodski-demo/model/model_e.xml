<?xml version="1.0" encoding="UTF-8"?>
<!--
  Agent E 模型文件 — 数据引用、脚本执行

  模型:
  - ReturnAPI: 接口返回值测试模型
  - EvaluateResult: JS evaluate 结果验证模型

  注意: 数据库模型已迁移到 model_db.xml (v5.0+)
-->
<models>

    <!-- 接口返回值测试模型（用于 send 关键字） -->
    <model name="ReturnAPI" type="interface" servicename="">
        <element name="_method" type="interface">
            <location type="static">POST</location>
        </element>
        <element name="_url" type="interface">
            <location type="static">GlobalValue.DefaultValue.URL/api/login</location>
        </element>
        <element name="username" type="interface">
            <location type="field">username</location>
        </element>
        <element name="password" type="interface">
            <location type="field">password</location>
        </element>
    </model>

    <!-- JS evaluate 验证模型 -->
    <model name="EvaluateResult" type="ui" servicename="">
        <element name="pageTitle" type="web">
            <type>text</type>
            <location type="id">pageTitle</location>
            <desc>页面标题隐藏 div</desc>
        </element>
    </model>

</models>
