<?xml version="1.0" encoding="UTF-8"?>
<models>
  <!-- 询价单列表页（维修厂视角） -->
  <model name="InquiryListPage">
    <!-- 询价单列表 -->
    <element name="inquiryList" type="css" value=".inquiry-list,[class*='inquiry']" desc="询价单列表"/>
    <!-- 新建询价单按钮 -->
    <element name="newInquiryBtn" type="xpath" value="//*[contains(text(),'新建询价单')]" desc="新建询价单按钮"/>
    <!-- 询价单状态标签 -->
    <element name="statusTag" type="css" value="[class*='status'],[class*='tag']" desc="状态标签"/>
  </model>
  
  <!-- 发布询价页（维修厂） -->
  <model name="PublishInquiryPage">
    <!-- VIN码输入框 -->
    <element name="vinInput" type="css" value="#vin" desc="VIN码输入框"/>
    <!-- 按品类选择 -->
    <element name="selectByCategory" type="xpath" value="//*[contains(text(),'按品类选择')]" desc="按品类选择"/>
    <!-- 按常用件选择 -->
    <element name="selectByFrequent" type="xpath" value="//*[contains(text(),'按常用件选择')]" desc="按常用件选择"/>
    <!-- 自助查找配件 -->
    <element name="searchParts" type="xpath" value="//*[contains(text(),'自助查找配件')]" desc="自助查找配件"/>
    <!-- 提交询价按钮 -->
    <element name="submitInquiry" type="xpath" value="//*[contains(text(),'提交询价')]" desc="提交询价按钮"/>
    <!-- 保存草稿 -->
    <element name="saveDraft" type="xpath" value="//*[contains(text(),'保存草稿')]" desc="保存草稿"/>
    <!-- 收货信息 -->
    <element name="receiverName" type="css" value="#receiverName" desc="收货人"/>
    <element name="contactPhone" type="css" value="#contactNumber" desc="联系电话"/>
    <element name="detailAddress" type="css" value="#inquiryDetailAddress" desc="详细地址"/>
  </model>
  
  <!-- 报价列表页（维修厂-查看供应商报价） -->
  <model name="QuotationListPage">
    <!-- 报价列表 -->
    <element name="quotationList" type="css" value=".quotation-list,[class*='quotation']" desc="报价列表"/>
    <!-- 报价商品名称 -->
    <element name="productName" type="css" value="[class*='product-name']" desc="商品名称"/>
    <!-- 单价 -->
    <element name="price" type="css" value="[class*='price']" desc="单价"/>
    <!-- 供应商名称 -->
    <element name="supplierName" type="css" value="[class*='supplier']" desc="供应商名称"/>
    <!-- 立即下单按钮 -->
    <element name="orderNow" type="xpath" value="//*[contains(text(),'立即下单')]" desc="立即下单"/>
    <!-- 加入购物车 -->
    <element name="addToCart" type="xpath" value="//*[contains(text(),'加入购物车')]" desc="加入购物车"/>
  </model>
</models>