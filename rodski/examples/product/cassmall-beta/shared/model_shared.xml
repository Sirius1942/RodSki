<?xml version="1.0" encoding="UTF-8"?>
<models>
  <!-- 登录页模型 - 跨模块共享 -->
  <model name="LoginPage">
    <!-- 账号登录 Tab -->
    <element name="accountTab">
      <location type="css">.login-tab-account,.account-tab,[class*='tab'][class*='account']</location>
      <desc>账号登录页签</desc>
    </element>
    <!-- 用户名输入框 -->
    <element name="username">
      <location type="css">input[type='text'],input[placeholder*='账号'],input[placeholder*='手机']</location>
      <desc>用户名输入框</desc>
    </element>
    <!-- 密码输入框 -->
    <element name="password">
      <location type="css">input[type='password']</location>
      <desc>密码输入框</desc>
    </element>
    <!-- 协议复选框 -->
    <element name="agreeCheckbox">
      <location type="css">input[type='checkbox'],.agree-checkbox,[class*='checkbox']</location>
      <desc>同意协议复选框</desc>
    </element>
    <!-- 登录按钮 -->
    <element name="loginBtn">
      <location type="css">button[type='submit'],.login-btn,[class*='login']</location>
      <desc>登录按钮</desc>
    </element>
    <!-- 协议提示弹窗 - 同意按钮 -->
    <element name="agreeConfirm">
      <location type="css">.dialog-confirm,.modal-confirm,button:has-text('同意'),button:has-text('确定')</location>
      <desc>弹窗同意按钮</desc>
    </element>
  </model>
</models>
