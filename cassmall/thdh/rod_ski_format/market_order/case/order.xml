<?xml version="1.0" encoding="UTF-8"?>
<cases>
  <!-- 小李-订单列表 -->
  <case id="cassmall_market_order_list" title="小李-订单列表" execute="是" description="小李（维修厂）访问订单列表页面">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="3"/>
      <test_step action="type" model="LoginPage" data="xiaoli_login"/>
      <test_step action="wait" data="5"/>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/portal"/>
      <test_step action="wait" data="2"/>
    </pre_process>
    <test_case>
      <!-- 进入订单列表页面 -->
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/order/list"/>
      <test_step action="wait" data="3"/>
      <!-- 获取订单列表 -->
      <test_step action="send" model="MarketOrderList" data="MOL001"/>
      <test_step action="verify" model="MarketOrderList_verify" data="MOLV001"/>
      <!-- 获取用户信息 -->
      <test_step action="send" model="MarketUserMain" data="MUM001"/>
      <test_step action="verify" model="MarketUserMain_verify" data="MUMV001"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>

  <!-- 小李-询价页面 -->
  <case id="cassmall_market_agent_buy" title="小李-询价页面" execute="是" description="小李访问询价页面">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="3"/>
      <test_step action="type" model="LoginPage" data="xiaoli_login"/>
      <test_step action="wait" data="5"/>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/portal"/>
      <test_step action="wait" data="2"/>
    </pre_process>
    <test_case>
      <!-- 进入询价页面 -->
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/agentBuy/"/>
      <test_step action="wait" data="3"/>
      <!-- 检查询价权限 -->
      <test_step action="send" model="MarketAuthInquiry" data="MAI001"/>
      <test_step action="verify" model="MarketAuthInquiry_verify" data="MAIV001"/>
      <!-- 获取可用权限 -->
      <test_step action="send" model="MarketGarageRightAvailable" data="MGRA001"/>
      <test_step action="verify" model="MarketGarageRightAvailable_verify" data="MGRAV001"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>

  <!-- 小李-会员和积分信息 -->
  <case id="cassmall_market_member_points" title="小李-会员和积分信息" execute="是" description="小李查看会员信息和积分">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="3"/>
      <test_step action="type" model="LoginPage" data="xiaoli_login"/>
      <test_step action="wait" data="5"/>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/portal"/>
      <test_step action="wait" data="2"/>
    </pre_process>
    <test_case>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/order/list"/>
      <test_step action="wait" data="3"/>
      <!-- 获取会员信息 -->
      <test_step action="send" model="MarketMemberInfo" data="MMI001"/>
      <test_step action="verify" model="MarketMemberInfo_verify" data="MMIV001"/>
      <!-- 获取积分 -->
      <test_step action="send" model="MarketUserPoint" data="MUP001"/>
      <test_step action="verify" model="MarketUserPoint_verify" data="MUPV001"/>
      <!-- 获取金币 -->
      <test_step action="send" model="MarketGoldcoinAccount" data="MGA001"/>
      <test_step action="verify" model="MarketGoldcoinAccount_verify" data="MGAV001"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>
</cases>
