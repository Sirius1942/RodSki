<?xml version="1.0" encoding="UTF-8"?>
<models>
  <model name="LoginPage">
    <!-- 账号登录 Tab -->
    <element name="accountTab" type="css" value="span[type=PASSWORD]" desc="账号登录页签"/>
    <!-- 用户名输入框 -->
    <element name="username" type="css" value="#userName" desc="用户名输入框"/>
    <!-- 密码输入框 -->
    <element name="password" type="css" value="#password" desc="密码输入框"/>
    <!-- 同意协议复选框（label 标签） -->
    <element name="agreeCheckbox" type="css" value="label.br-checkbox" desc="同意协议复选框"/>
    <!-- 登录按钮 -->
    <element name="loginBtn" type="css" value=".btn-submit" desc="登录按钮"/>
  </model>
</models>
