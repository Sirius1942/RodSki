<?xml version="1.0" encoding="UTF-8"?>
<models>
  <!-- 订单页面模型 -->
  <model name="PurchaseOrder">
    <!-- 采购订单 - 新建/提交按钮 -->
    <element name="newOrderBtn" type="ocr" value="新建采购订单" desc="新建采购订单按钮"/>
    <!-- 商品搜索 -->
    <element name="productSearch" type="css" value="input[placeholder*='商品'],input[placeholder*='搜索']" desc="商品搜索"/>
    <!-- 数量输入 -->
    <element name="quantity" type="css" value="input[type='number']" desc="数量输入"/>
    <!-- 提交订单 -->
    <element name="submitBtn" type="ocr" value="提交" desc="提交按钮"/>
    <!-- 订单号（结果） -->
    <element name="orderNo" type="ocr" value="订单号" desc="订单号"/>
    <!-- 确认下单按钮 -->
    <element name="confirmOrder" type="ocr" value="确认下单" desc="确认下单"/>
  </model>
</models>
