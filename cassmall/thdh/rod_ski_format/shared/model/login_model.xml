<?xml version="1.0" encoding="UTF-8"?>
<!--
  登录页模型 - 共享
  用于商家端和维修厂端登录
-->
<models>

  <!-- 登录页模型 -->
  <model name="LoginPage" servicename="">
    <element name="accountTab" interfacename="" group="" type="web">
      <type>click</type>
      <location type="xpath" item="">//*[contains(text(),'账号登录')]</location>
      <desc>账号登录Tab</desc>
    </element>
    <element name="username" interfacename="" group="" type="web">
      <type>input</type>
      <location type="css" item="">#userName</location>
      <desc>用户名输入框</desc>
    </element>
    <element name="password" interfacename="" group="" type="web">
      <type>input</type>
      <location type="css" item="">#password</location>
      <desc>密码输入框</desc>
    </element>
    <element name="agreeCheckbox" interfacename="" group="" type="web">
      <type>click</type>
      <location type="css" item="">label.br-checkbox</location>
      <desc>同意协议复选框</desc>
    </element>
    <element name="loginBtn" interfacename="" group="" type="web">
      <type>button</type>
      <location type="css" item="">.btn-submit</location>
      <desc>登录按钮</desc>
    </element>
  </model>

</models>
