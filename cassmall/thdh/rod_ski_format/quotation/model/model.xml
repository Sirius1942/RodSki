<?xml version="1.0" encoding="UTF-8"?>
<models>
  <!-- 登录页模型（来自 login 模块） -->
  <model name="LoginPage">
    <!-- 账号登录 Tab -->
    <element name="accountTab" type="css" value="span[type=PASSWORD]" desc="账号登录页签"/>
    <!-- 用户名输入框 -->
    <element name="username" type="css" value="#userName" desc="用户名输入框"/>
    <!-- 密码输入框 -->
    <element name="password" type="css" value="#password" desc="密码输入框"/>
    <!-- 同意协议复选框（label 标签） -->
    <element name="agreeCheckbox" type="css" value="label.br-checkbox" desc="同意协议复选框"/>
    <!-- 登录按钮 -->
    <element name="loginBtn" type="css" value=".btn-submit" desc="登录按钮"/>
  </model>

  <!-- 发布询价页（维修厂-小李）- 用于发布新询价 -->
  <model name="InquiryPage">
    <!-- VIN码输入框 -->
    <element name="vin" type="css" value="#vin" desc="VIN码输入框"/>
    <!-- 配件名称/原厂零件号（第1行） -->
    <element name="needsName" type="css" value="textarea[name=needName]" desc="配件名称输入框（第1行）"/>
    <!-- 数量（第1行） -->
    <element name="needQuantity" type="css" value="input[name=needQuantity]" desc="数量输入框（第1行）"/>
    <!-- 配件描述备注 -->
    <element name="qualityRemarks" type="css" value="#new-quality-remarks" desc="质量要求备注"/>
    <!-- 发布询价/保存按钮 -->
    <element name="submitInquiry" type="css" value=".save-inquiry" desc="发布询价按钮"/>
    <!-- 品牌输入（当VIN无结果时使用） -->
    <element name="carBrand" type="css" value="#otherCarBrandName" desc="车辆品牌输入"/>
    <!-- 车型输入 -->
    <element name="carModel" type="css" value="#otherCarModelName" desc="车辆型号输入"/>
  </model>

  <!-- 报价列表页（维修厂-小李） -->
  <model name="QuotationListPage">
    <!-- 询价号列（用于定位报价行） -->
    <element name="inquiryNo" type="css" value="[class*='inquiry-no'], td:nth-child(3)" desc="询价号单元格"/>
    <!-- 状态列 -->
    <element name="status" type="css" value="[class*='status'], td:nth-child(2)" desc="状态单元格"/>
    <!-- 报价数量列 -->
    <element name="quoteCount" type="css" value="[class*='quote-count'], td:nth-child(3)" desc="报价数量"/>
    <!-- 查看报价按钮 -->
    <element name="viewQuote" type="xpath" value="//*[contains(text(),'查看报价')]" desc="查看报价按钮"/>
    <!-- 立即购买/选购按钮 -->
    <element name="buyNow" type="xpath" value="//*[contains(text(),'选购') or contains(text(),'立即购买')]" desc="立即购买/选购按钮"/>
    <!-- 配件名称列 -->
    <element name="productName" type="css" value="[class*='product-name'], td:nth-child(7)" desc="配件名称"/>
    <!-- 零件号列 -->
    <element name="partNo" type="css" value="[class*='part-no'], td:nth-child(8)" desc="零件号"/>
    <!-- 询价时间列 -->
    <element name="inquiryTime" type="css" value="[class*='inquiry-time'], td:nth-child(10)" desc="询价时间"/>
    <!-- 分页输入框 -->
    <element name="pageInput" type="css" value="#kkpager_btn_go_input" desc="分页跳转输入框"/>
    <!-- 分页跳转按钮 -->
    <element name="pageGo" type="css" value="#kkpager_btn_go" desc="分页跳转按钮"/>
    <!-- 时间范围开始 -->
    <element name="startDate" type="css" value="#BeginTime" desc="询价时间开始"/>
    <!-- 时间范围结束 -->
    <element name="endDate" type="css" value="#EndTime" desc="询价时间结束"/>
    <!-- 搜索框-VIN -->
    <element name="vinSearch" type="css" value="input[name=vin]" desc="VIN搜索框"/>
    <!-- 搜索框-配件名称/零件号 -->
    <element name="partSearch" type="css" value="input[name=userNeed]" desc="配件名称搜索框"/>
  </model>

  <!-- 报价商品详情/选购页 -->
  <model name="QuotationDetailPage">
    <!-- 商品名称 -->
    <element name="productName" type="css" value="[class*='product-name'], .goods-name" desc="商品名称"/>
    <!-- 单价 -->
    <element name="price" type="css" value="[class*='price'], .goods-price" desc="单价"/>
    <!-- 数量输入 -->
    <element name="quantity" type="css" value="input[type='number'], input[name='quantity']" desc="数量输入框"/>
    <!-- 加入购物车按钮 -->
    <element name="addToCart" type="xpath" value="//*[contains(text(),'加入购物车') or contains(text(),'选购')]" desc="加入购物车/选购按钮"/>
    <!-- 立即购买按钮 -->
    <element name="buyNow" type="xpath" value="//*[contains(text(),'立即购买')]" desc="立即购买按钮"/>
    <!-- 确认购买按钮 -->
    <element name="confirmBuy" type="xpath" value="//*[contains(text(),'确认购买')]" desc="确认购买按钮"/>
  </model>

  <!-- 购物车页面 -->
  <model name="CartPage">
    <!-- 购物车商品列表 -->
    <element name="cartItems" type="css" value="[class*='cart-item'], .cart-goods-list" desc="购物车商品列表"/>
    <!-- 去结算按钮 -->
    <element name="checkout" type="xpath" value="//*[contains(text(),'去结算')]" desc="去结算按钮"/>
    <!-- 全选复选框 -->
    <element name="selectAll" type="css" value="[class*='select-all'], input[type='checkbox']" desc="全选复选框"/>
    <!-- 商品勾选框 -->
    <element name="itemCheck" type="css" value="input[type='checkbox']" desc="商品勾选框"/>
    <!-- 合计金额 -->
    <element name="totalAmount" type="css" value="[class*='total-amount'], [class*='amount']" desc="合计金额"/>
  </model>

  <!-- 提交订单页 -->
  <model name="CheckoutPage">
    <!-- 收货人姓名 -->
    <element name="receiverName" type="css" value="#receiverName" desc="收货人姓名"/>
    <!-- 联系电话 -->
    <element name="contactTel" type="css" value="#contactNumber" desc="联系电话"/>
    <!-- 详细地址 -->
    <element name="address" type="css" value="#inquiryDetailAddress" desc="详细地址"/>
    <!-- 省份选择 -->
    <element name="province" type="css" value="#provinceGeoId" desc="省份选择"/>
    <!-- 城市选择 -->
    <element name="city" type="css" value="#cityGeoId" desc="城市选择"/>
    <!-- 区县选择 -->
    <element name="county" type="css" value="#countyGeoId" desc="区县选择"/>
    <!-- 物流方式选择 -->
    <element name="logistics" type="css" value="[class*='logistics'], [class*='express']" desc="物流方式"/>
    <!-- 提交订单按钮 -->
    <element name="submitOrder" type="xpath" value="//*[contains(text(),'提交订单') or contains(text(),'确认提交')]" desc="提交订单按钮"/>
    <!-- 订单号（结果） -->
    <element name="orderNo" type="css" value="[class*='order-no'], [class*='result-order']" desc="订单号"/>
  </model>
</models>
