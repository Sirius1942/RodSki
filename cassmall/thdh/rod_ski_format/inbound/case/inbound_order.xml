      <test_step action="wait" data="5"/>
    </pre_process>
    <test_case>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/seller#/merchant/warehouse-entry/list"/>
      <test_step action="wait" data="3"/>
      <!-- 查询机构入库单 -->
      <test_step action="send" model="InboundOrderListOrg" data="IO001"/>
      <test_step action="verify" model="InboundOrderListOrg_verify" data="IOV001"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>

  <!-- 小辉-查询入库单状态枚举 -->
  <case id="cassmall_inbound_status_enum" title="小辉-查询入库单状态枚举" execute="是" description="小辉获取入库单状态枚举">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="3"/>
      <test_step action="type" model="LoginPage" data="xiaohui_login"/>
      <test_step action="wait" data="5"/>
    </pre_process>
    <test_case>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/seller#/merchant/warehouse-entry/list"/>
      <test_step action="wait" data="3"/>
      <!-- 查询状态枚举 -->
      <test_step action="send" model="CommonDictionary" data="CD001"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>
</cases>
