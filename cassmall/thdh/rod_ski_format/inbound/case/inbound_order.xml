      <test_step action="wait" data="5"/>
    </pre_process>
    <test_case>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/seller#/merchant/warehouse-entry/list"/>
      <test_step action="wait" data="3"/>
      <!-- 查询逾期统计 -->
      <test_step action="send" model="InboundOrderOverdueStats" data="IOS001"/>
      <test_step action="verify" model="InboundOrderOverdueStats_verify" data="IOSV001"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>

  <!-- 小辉-机构入库单列表 -->
  <case id="cassmall_inbound_org_list" title="小辉-机构入库单列表" execute="是" description="小辉查看机构入库单列表">
