<?xml version="1.0" encoding="UTF-8"?>
<cases>
  <!-- 小辉-入库单列表查询 -->
  <case id="cassmall_inbound_order_list" title="小辉-入库单列表查询" execute="是" description="小辉（商家端）登录后访问入库单列表页面">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="3"/>
      <test_step action="type" model="LoginPage" data="xiaohui_login"/>
      <test_step action="wait" data="5"/>
    </pre_process>
    <test_case>
      <!-- 访问入库单列表页面 -->
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/seller#/merchant/warehouse-entry/list"/>
      <test_step action="wait" data="3"/>
      <!-- 发送入库单列表查询请求 -->
      <test_step action="send" model="InboundOrderList" data="I001"/>
      <test_step action="verify" model="InboundOrderList_verify" data="IV001"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>

  <!-- 小辉-入库单逾期统计 -->
  <case id="cassmall_inbound_overdue_stats" title="小辉-入库单逾期统计" execute="是" description="小辉查看入库单逾期统计">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="3"/>
