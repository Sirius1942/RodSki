  <case id="inbound_list_001" title="入库单列表-分页查询" execute="是" description="测试入库单列表分页查询接口" component_type="接口">
    <pre_process>
      <!-- 导航到商家端 -->
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="2"/>
      <!-- 登录商家端 -->
      <test_step action="type" model="LoginPage" data="xiaohui_login"/>
      <test_step action="wait" data="3"/>
    </pre_process>
    <test_case>
      <!-- 调用入库单列表接口 -->
      <test_step action="send" model="InboundOrderList" data="I001"/>
      <!-- 验证返回成功 -->
      <test_step action="verify" model="InboundOrderList" data="V001"/>
    </test_case>
    <post_process>
      <test_step action="close"/>
    </post_process>
  </case>

