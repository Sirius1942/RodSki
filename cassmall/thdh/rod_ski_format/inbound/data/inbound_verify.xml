<?xml version="1.0" encoding="UTF-8"?>
<!--
  入库单接口验证数据表 - 商家端入库单管理模块
  与 inbound/model/model.xml 中的接口模型配合 verify 关键字使用
  
  verify 批量接口验证原理：
  - send 执行后，HTTP 响应自动保存为 Return[-1]
  - verify 对接口类型元素从 Return[-1] 中读取实际值
  - 与本表期望值逐字段比较
-->
<datatables>

  <!-- 入库单列表验证数据 -->
  <datatable name="InboundOrderList">
    <!-- V001: 验证返回成功 -->
    <row id="V001" remark="验证返回成功">
      <field name="code">0</field>
    </row>
  </datatable>

  <!-- 入库单详情验证数据 -->
  <datatable name="InboundOrderDetail">
    <!-- V002: 验证详情返回成功 -->
    <row id="V002" remark="验证详情返回成功">
      <field name="code">0</field>
    </row>
    <!-- V003: 验证无效ID返回错误 -->
    <row id="V003" remark="验证无效ID返回错误">
      <field name="code">500</field>
    </row>
  </datatable>

  <!-- 创建入库单验证数据 -->
  <datatable name="InboundOrderCreate">
    <!-- V004: 验证创建成功 -->
    <row id="V004" remark="验证创建成功">
      <field name="code">0</field>
    </row>
  </datatable>

  <!-- 更新入库单验证数据 -->
  <datatable name="InboundOrderUpdate">
    <!-- V005: 验证更新成功 -->
    <row id="V005" remark="验证更新成功">
      <field name="code">0</field>
    </row>
  </datatable>

  <!-- 枚举字典验证数据 -->
  <datatable name="EnumDictionary">
    <!-- V006: 验证枚举返回成功 -->
    <row id="V006" remark="验证枚举返回成功">
      <field name="code">0</field>
    </row>
  </datatable>

</datatables>
