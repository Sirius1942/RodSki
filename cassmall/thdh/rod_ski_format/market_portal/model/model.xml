<?xml version="1.0" encoding="UTF-8"?>
<models>
  <!-- 登录页模型 -->
  <model name="LoginPage">
    <element name="accountTab" type="css" value="span[type=PASSWORD]" desc="账号登录页签"/>
    <element name="username" type="css" value="#userName" desc="用户名输入框"/>
    <element name="password" type="css" value="#password" desc="密码输入框"/>
    <element name="agreeCheckbox" type="css" value="label.br-checkbox" desc="同意协议复选框"/>
    <element name="loginBtn" type="css" value=".btn-submit" desc="登录按钮"/>
  </model>

  <!-- 首页接口 -->
  <model name="MarketPortal" type="interface">
    <element name="_method"><static>GET</static></element>
    <element name="_url"><static>/market/portal</static></element>
  </model>

  <!-- 首页验证模型 -->
  <model name="MarketPortal_verify" type="interface">
    <element name="code"><field>code</field></element>
    <element name="msg"><field>msg</field></element>
  </model>

  <!-- 首页楼层接口 -->
  <model name="MarketPortalFloor" type="interface">
    <element name="_method"><static>GET</static></element>
    <element name="_url"><static>/market/portal/getPortalFloor</static></element>
  </model>

  <!-- 首页楼层验证 -->
  <model name="MarketPortalFloor_verify" type="interface">
    <element name="code"><field>code</field></element>
  </model>

  <!-- 会员信息接口 -->
  <model name="MarketMemberInfo" type="interface">
    <element name="_method"><static>GET</static></element>
    <element name="_url"><static>/market/portal/memberInfo</static></element>
  </model>

  <!-- 会员信息验证 -->
  <model name="MarketMemberInfo_verify" type="interface">
    <element name="code"><field>code</field></element>
  </model>

  <!-- 品牌接口 -->
  <model name="MarketProductBrands" type="interface">
    <element name="_method"><static>POST</static></element>
    <element name="_url"><static>/market/portal/getProductBrands</static></element>
    <element name="_body_type"><static>json</static></element>
    <element name="brands"><field>brands</field></element>
  </model>

  <!-- 品牌验证 -->
  <model name="MarketProductBrands_verify" type="interface">
    <element name="code"><field>code</field></element>
  </model>

  <!-- 公告接口 -->
  <model name="MarketAnnouncements" type="interface">
    <element name="_method"><static>GET</static></element>
    <element name="_url"><static>/market/announcements/online</static></element>
  </model>

  <!-- 公告验证 -->
  <model name="MarketAnnouncements_verify" type="interface">
    <element name="code"><field>code</field></element>
  </model>

  <!-- 未读公告接口 -->
  <model name="MarketLastUnreadAnnouncement" type="interface">
    <element name="_method"><static>GET</static></element>
    <element name="_url"><static>/market/announcements/last-unread</static></element>
  </model>

  <!-- 未读公告验证 -->
  <model name="MarketLastUnreadAnnouncement_verify" type="interface">
    <element name="code"><field>code</field></element>
  </model>

  <!-- 用户信息接口 -->
  <model name="MarketUserMain" type="interface">
    <element name="_method"><static>GET</static></element>
    <element name="_url"><static>/market/user/main/garage</static></element>
  </model>

  <!-- 用户信息验证 -->
  <model name="MarketUserMain_verify" type="interface">
    <element name="code"><field>code</field></element>
  </model>

  <!-- 积分接口 -->
  <model name="MarketUserPoint" type="interface">
    <element name="_method"><static>GET</static></element>
    <element name="_url"><static>/market/points/userpoint</static></element>
  </model>

  <!-- 积分验证 -->
  <model name="MarketUserPoint_verify" type="interface">
    <element name="code"><field>code</field></element>
  </model>

  <!-- 金币账户接口 -->
  <model name="MarketGoldcoinAccount" type="interface">
    <element name="_method"><static>GET</static></element>
    <element name="_url"><static>/market/goldcoin/account</static></element>
  </model>

  <!-- 金币账户验证 -->
  <model name="MarketGoldcoinAccount_verify" type="interface">
    <element name="code"><field>code</field></element>
  </model>

  <!-- 购物车数量接口 -->
  <model name="MarketCartCount" type="interface">
    <element name="_method"><static>GET</static></element>
    <element name="_url"><static>/market/cart</static></element>
  </model>

  <!-- 消息未读数接口 -->
  <model name="MarketUnreadCount" type="interface">
    <element name="_method"><static>GET</static></element>
    <element name="_url"><static>/market/messages/unread_count</static></element>
  </model>
</models>
