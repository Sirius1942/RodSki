<?xml version="1.0" encoding="UTF-8"?>
<cases>
  <!-- 小辉-探索库存管理页面 -->
  <case id="cassmall_beta_explore_xiaohui" title="小辉-探索库存管理页面" execute="是" description="小辉账号（供应商）登录后探索库存管理相关页面，截图记录关键页面">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login#/merchant/home"/>
      <test_step action="wait" data="2"/>
    </pre_process>
    <test_case>
      <!-- 登录 -->
      <test_step action="type" model="LoginPage" data="xiaohui_login"/>
      <test_step action="wait" data="5"/>
      <test_step action="screenshot" data="inventory_01_logged_in.png"/>
      <!-- 探索页面结构 -->
      <test_step action="wait" data="3"/>
      <test_step action="screenshot" data="inventory_02_explore.png"/>
    </test_case>
    <post_process>
      <test_step action="close"/>
    </post_process>
  </case>

  <!-- 小辉-维护商品库存 -->
  <case id="cassmall_beta_inventory_xiaohui" title="小辉-维护商品库存" execute="是" description="小辉账号（供应商）登录后，维护商品库存信息">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login#/merchant/home"/>
      <test_step action="wait" data="2"/>
    </pre_process>
    <test_case>
      <!-- 登录 -->
      <test_step action="type" model="LoginPage" data="xiaohui_login"/>
      <test_step action="wait" data="5"/>
      <test_step action="screenshot" data="inventory_maintain_01_logged_in.png"/>
      <!-- 等待页面稳定 -->
      <test_step action="wait" data="3"/>
      <test_step action="screenshot" data="inventory_maintain_02_explore.png"/>
      <!-- 编辑库存 -->
      <test_step action="wait" data="2"/>
      <test_step action="screenshot" data="inventory_maintain_03_edited.png"/>
    </test_case>
    <post_process>
      <test_step action="close"/>
    </post_process>
  </case>
</cases>
