<?xml version="1.0" encoding="UTF-8"?>
<cases>
  <!-- 小李-购物车页面 -->
  <case id="cassmall_market_cart" title="小李-购物车页面" execute="是" description="小李（维修厂）进入购物车页面，查看已选商品">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="3"/>
      <test_step action="type" model="LoginPage" data="xiaoli_login"/>
      <test_step action="wait" data="5"/>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/portal"/>
      <test_step action="wait" data="2"/>
    </pre_process>
    <test_case>
      <!-- 进入购物车页面 -->
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/cart"/>
      <test_step action="wait" data="3"/>
      <!-- 获取购物车数据 -->
      <test_step action="send" model="MarketCart" data="MC001"/>
      <test_step action="verify" model="MarketCart_verify" data="MCV001"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>

  <!-- 小李-查看顶部栏和消息 -->
  <case id="cassmall_market_topbar" title="小李-查看顶部栏和消息数" execute="是" description="小李查看顶部栏数据和未读消息数">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="3"/>
      <test_step action="type" model="LoginPage" data="xiaoli_login"/>
      <test_step action="wait" data="5"/>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/portal"/>
      <test_step action="wait" data="2"/>
    </pre_process>
    <test_case>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/cart"/>
      <test_step action="wait" data="3"/>
      <!-- 获取顶部栏 -->
      <test_step action="send" model="MarketTopbar" data="MT001"/>
      <test_step action="verify" model="MarketTopbar_verify" data="MTV001"/>
      <!-- 获取未读消息 -->
      <test_step action="send" model="MarketUnreadCount" data="MUC001"/>
      <test_step action="verify" model="MarketUnreadCount_verify" data="MUCV001"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>
</cases>
