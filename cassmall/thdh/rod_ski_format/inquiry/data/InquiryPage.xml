<?xml version="1.0" encoding="UTF-8"?>
<datatable name="InquiryPage">
  <!-- 步骤1：只填VIN -->
  <row id="I001_fill">
    <field name="vin">WBAKB4106BC920125</field>
  </row>
  
  <!-- 步骤2：点击配件名称触发VIN解析弹窗 -->
  <row id="I001_trigger">
    <field name="needsName">click</field>
  </row>
  
  <!-- 步骤3：处理弹窗-点击追加 -->
  <row id="I001_add">
    <field name="addInquiryDemand">click</field>
  </row>
  
  <!-- 步骤4：填写数量和备注 -->
  <row id="I001_extra">
    <field name="needQuantity">2</field>
    <field name="qualityRemarks">需要原厂配件</field>
  </row>
  
  <!-- 步骤5：发布 -->
  <row id="I001_submit">
    <field name="submitInquiry">click</field>
  </row>
</datatable>
