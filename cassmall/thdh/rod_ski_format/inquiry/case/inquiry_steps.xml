<?xml version="1.0" encoding="UTF-8"?>
<cases>
  <!-- 小李发布询价 - 分步执行版 -->
  <case id="cassmall_inquiry_xiaoli_steps" title="小李发布询价-分步版" execute="是" description="小李发布询价单-验证创建成功">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="3"/>
      <test_step action="type" model="LoginPage" data="xiaoli_login"/>
      <test_step action="wait" data="5"/>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/portal"/>
      <test_step action="wait" data="2"/>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/agentBuy/"/>
      <test_step action="wait" data="3"/>
    </pre_process>
    <test_case>
      <!-- 步骤1：填VIN -->
      <test_step action="type" model="InquiryPage" data="S01_fill_vin"/>
      <test_step action="wait" data="2"/>
      <!-- 步骤2：点击配件名称触发弹窗 -->
      <test_step action="type" model="InquiryPage" data="S02_trigger_popup"/>
      <test_step action="wait" data="3"/>
      <!-- 步骤3：点击追加 -->
      <test_step action="type" model="InquiryPage" data="S03_add_demand"/>
      <test_step action="wait" data="2"/>
      <!-- 步骤4：填数量备注 -->
      <test_step action="type" model="InquiryPage" data="S04_extra"/>
      <test_step action="wait" data="2"/>
      <!-- 步骤5：提交 -->
      <test_step action="type" model="InquiryPage" data="S05_submit"/>
      <test_step action="wait" data="5"/>
      <!-- 截图 -->
      <test_step action="screenshot" data="cassmall_inquiry_steps_result.png"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>
</cases>
