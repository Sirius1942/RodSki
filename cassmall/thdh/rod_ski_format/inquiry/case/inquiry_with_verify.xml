<?xml version="1.0" encoding="UTF-8"?>
<cases>
  <case id="cassmall_inquiry_with_verify" title="小李发布询价并验证" execute="是">
    <pre_process>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/passport/login"/>
      <test_step action="wait" data="3"/>
      <test_step action="type" model="LoginPage" data="xiaoli_login"/>
      <test_step action="wait" data="5"/>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/portal"/>
      <test_step action="wait" data="2"/>
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/agentBuy/"/>
      <test_step action="wait" data="3"/>
    </pre_process>
    <test_case>
      <!-- S1: 填VIN -->
      <test_step action="type" model="InquiryPage" data="S1"/>
      <test_step action="wait" data="2"/>
      <!-- S2: 触发弹窗 -->
      <test_step action="type" model="InquiryPage" data="S2"/>
      <test_step action="wait" data="3"/>
      <!-- S3: 填配件名称 -->
      <test_step action="type" model="InquiryPage" data="S3"/>
      <test_step action="wait" data="2"/>
      <!-- S4: 点追加 -->
      <test_step action="type" model="InquiryPage" data="S4"/>
      <test_step action="wait" data="2"/>
      <!-- S5: 滚动发布按钮 -->
      <test_step action="type" model="InquiryPage" data="S5"/>
      <test_step action="wait" data="1"/>
      <!-- S6: 点发布 -->
      <test_step action="type" model="InquiryPage" data="S6"/>
      <test_step action="wait" data="5"/>
      <test_step action="screenshot" data="after_inquiry_submit.png"/>
      <!-- 跳转列表 -->
      <test_step action="navigate" data="https://ec-hwbeta.casstime.com/market/inquirys"/>
      <test_step action="wait" data="3"/>
      <test_step action="screenshot" data="quotation_list.png"/>
      <!-- 查询验证 -->
      <test_step action="type" model="QuotationListPage" data="Q1"/>
      <test_step action="wait" data="3"/>
      <test_step action="screenshot" data="after_search.png"/>
    </test_case>
    <post_process>
      <test_step action="close" data=""/>
    </post_process>
  </case>
</cases>
