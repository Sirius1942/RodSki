<?xml version="1.0" encoding="UTF-8"?>
<models>
  <!-- 登录页模型 -->
  <model name="LoginPage">
    <element name="accountTab" type="css" value="span[type=PASSWORD]" desc="账号登录Tab"/>
    <element name="username" type="css" value="#userName" desc="用户名"/>
    <element name="password" type="css" value="#password" desc="密码"/>
    <element name="agreeCheckbox" type="css" value="label.br-checkbox" desc="同意协议"/>
    <element name="loginBtn" type="css" value=".btn-submit" desc="登录按钮"/>
  </model>

  <!-- 发布询价页 -->
  <model name="InquiryPage">
    <element name="vin" type="css" value="#vin" desc="VIN码输入框"/>
    <element name="needsName" type="css" value="textarea[name=needName]" desc="配件名称触发弹窗"/>
    <element name="addInquiryDemand" type="text" value="追加询价需求" desc="追加询价需求"/>
    <element name="needQuantity" type="css" value="textarea[name=needQuantity]" desc="数量"/>
    <element name="qualityRemarks" type="css" value="#new-quality-remarks" desc="质量要求"/>
    <element name="submitInquiry" type="css" value=".save-inquiry" desc="发布按钮"/>
  </model>

  <!-- 供应商询价单列表页 -->
  <model name="SupplierInquiryPage">
    <element name="inquiryList" type="css" value=".inquiry-list,[class*=inquiry-list]" desc="询价单列表"/>
    <element name="inquiryNo" type="css" value="[class*=inquiry-no]" desc="询价单号"/>
  </model>

  <!-- 供应商报价页 -->
  <model name="QuotePage">
    <element name="quotePrice" type="css" value="input[placeholder*=报价]" desc="报价输入框"/>
    <element name="quantity" type="css" value="input[type=number]" desc="数量"/>
    <element name="submitQuote" type="text" value="提交报价" desc="提交报价"/>
  </model>

  <!-- 询价单列表页（采购方视角） -->
  <model name="QuotationListPage">
    <element name="vinInput" type="name" value="vin" desc="VIN查询输入框"/>
    <element name="searchBtn" type="text" value="查询" desc="查询按钮"/>
    <element name="inquiryTable" type="css" value="table, [class*=table]" desc="询价单表格"/>
    <element name="newInquiryBtn" type="text" value="新建" desc="新建按钮"/>
  </model>

  <!-- 询价单列表页（维修厂视角） -->
  <model name="InquiryListPage">
    <element name="vinSearch" type="css" value="input[name=vin]" desc="VIN搜索框"/>
    <element name="partSearch" type="css" value="input[name=userNeed]" desc="配件名称搜索框"/>
    <element name="inquiryNo" type="css" value="[class*=inquiry-no]" desc="询价单号"/>
    <element name="status" type="css" value="[class*=status]" desc="状态"/>
  </model>

  <!-- 追加询价弹窗模型 -->
  <model name="AppendPopup">
    <element name="noAppendNew" type="xpath" value="//*[contains(text(),'不追加，发布新询价单')]" desc="不追加，发布新询价单按钮"/>
    <element name="addMore" type="xpath" value="//*[contains(text(),'追加询价需求')]" desc="追加询价需求按钮"/>
    <element name="cancel" type="text" value="取消" desc="取消按钮"/>
  </model>
</models>
