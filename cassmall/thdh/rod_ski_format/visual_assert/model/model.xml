<?xml version="1.0" encoding="UTF-8"?>
<models>
  <!-- 登录页模型 -->
  <model name="LoginPage">
    <element name="accountTab" type="css" value="span[type=PASSWORD]" desc="账号登录Tab"/>
    <element name="username" type="css" value="#userName" desc="用户名"/>
    <element name="password" type="css" value="#password" desc="密码"/>
    <element name="agreeCheckbox" type="css" value="label.br-checkbox" desc="同意协议"/>
    <element name="loginBtn" type="css" value=".btn-submit" desc="登录按钮"/>
  </model>

  <!-- 维修厂首页 Portal -->
  <model name="MarketPortalPage">
    <element name="portalNav" type="css" value="[class*=nav],nav,[class*=menu]" desc="顶部导航"/>
    <element name="portalTitle" type="css" value="[class*=title],h1,h2" desc="页面标题"/>
    <element name="portalContent" type="css" value="[class*=content],main" desc="主体内容"/>
  </model>

  <!-- 发布询价页 -->
  <model name="InquiryPublishPage">
    <element name="vinInput" type="css" value="#vin" desc="VIN输入框"/>
    <element name="partNameInput" type="css" value="textarea[name=needName]" desc="配件名称输入"/>
    <element name="quantityInput" type="css" value="textarea[name=needQuantity]" desc="数量输入"/>
    <element name="qualityRemarks" type="css" value="#new-quality-remarks" desc="质量要求"/>
    <element name="publishBtn" type="css" value=".save-inquiry" desc="发布询价按钮"/>
  </model>

  <!-- 供应商工作台 -->
  <model name="SellerHomePage">
    <element name="topNav" type="css" value="[class*=nav],nav,[class*=header]" desc="顶部菜单"/>
    <element name="sidebarMenu" type="css" value="[class*=sidebar],[class*=menu]" desc="侧边菜单"/>
    <element name="inquiryManage" type="xpath" value="//*[contains(text(),'询价单管理')]" desc="询价单管理入口"/>
    <element name="quoteManage" type="xpath" value="//*[contains(text(),'报价管理')]" desc="报价管理入口"/>
  </model>

  <!-- 报价列表页 -->
  <model name="QuoteListPage">
    <element name="quoteListHeader" type="css" value="[class*=header],thead,[class*=table-head]" desc="列表头部"/>
    <element name="quoteListTable" type="css" value="table,[class*=table]" desc="报价列表表格"/>
  </model>
</models>
