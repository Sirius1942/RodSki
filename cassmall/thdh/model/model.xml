<?xml version="1.0" encoding="UTF-8"?>
<models>
    <!-- 登录页面模型 -->
    <model name="LoginPage">
        <element name="accountLoginTab" type="xpath" value="//div[contains(text(),'账号登录')]"/>
        <element name="phoneInput" type="xpath" value="//input[@placeholder='请输入手机号']"/>
        <element name="passwordInput" type="xpath" value="//input[@placeholder='请输入密码']"/>
        <element name="agreeCheckbox" type="xpath" value="//input[@type='checkbox']"/>
        <element name="loginBtn" type="xpath" value="//button[contains(text(),'登录')]"/>
    </model>
</models>
